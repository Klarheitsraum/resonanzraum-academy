# Kopiere diese Datei zu ".env" und trag deinen echten Console-API-Key ein.
# Die ".env"-Datei niemals in Git einchecken oder öffentlich teilen.

ANTHROPIC_API_KEY=sk-ant-dein-eigener-key-hier

# Modell für den Weg "Resonanz" – claude-sonnet-5 ist die aktuelle Sonnet-Generation (Stand: Juli 2026)
CLAUDE_MODEL=claude-sonnet-5

# Optional: Zweiter Weg "Klarheit" über OpenAI/ChatGPT.
# Ohne diesen Key funktioniert "Resonanz" trotzdem ganz normal weiter.
OPENAI_API_KEY=sk-dein-openai-key-hier
OPENAI_MODEL=gpt-5.5

# Persistenter Raumspeicher (empfohlen, kostenloser Tarif reicht).
# Kostenloses Konto: https://console.upstash.com -> Redis-Datenbank erstellen
# -> "REST API"-Werte hier eintragen. Ohne diese Werte läuft der Raum nur im
# Arbeitsspeicher (verliert Inhalte bei jedem Neustart/Kaltstart).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Name, der automatisch als Administrator (Schwelle 4, Raumkörper 13) erkannt wird
ADMIN_NAME=Thomas

# Zugangscode für die Academy. OHNE diesen Wert ist der Raum öffentlich
# erreichbar - jede Person mit dem Link kann schreiben und Kosten verursachen.
# Wähle einen eigenen Code und gib ihn nur echten Teilnehmenden weiter.
ACADEMY_ACCESS_CODE=dein-eigener-code-hier

# Port, auf dem der Server lokal läuft
PORT=3000
